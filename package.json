{
  "name": "web-extension-store-screenshot-tool",
  "version": "0.1.1",
  "description": "Desktop screenshot and PNG export tool for Web extension store listing assets.",
  "author": "Un1quer",
  "repository": {
    "type": "git",
    "url": "https://github.com/Un1quer23/web-extension-store-screenshot-tool.git"
  },
  "homepage": "https://github.com/Un1quer23/web-extension-store-screenshot-tool/releases/latest",
  "bugs": {
    "url": "https://github.com/Un1quer23/web-extension-store-screenshot-tool/issues"
  },
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist:portable": "npm run build && electron-builder --win portable",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.web-extension-store-screenshot-tool.app",
    "productName": "Web Extension Store Screenshot Tool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright/**",
      "node_modules/playwright-core/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "electron-vite": "^4.0.0",
    "lucide-react": "^0.468.0",
    "playwright": "^1.57.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^2.1.8"
  }
}
